PORT=5000
NODE_ENV=development

# ==========================================
# REQUIRED ENVIRONMENT VARIABLES
# ==========================================

# MongoDB Connection String
# IMPORTANT: If your password contains special characters like @ # $ % : / ? & =
# you MUST encode them using percent-encoding (e.g. @ becomes %40, # becomes %23)
# Example: Original password "my@pass#123" -> encoded "my%40pass%23123"
MONGO_URI=mongodb+srv://<username>:<encodedPassword>@cluster.mongodb.net/dbname?retryWrites=true&w=majority

# JWT Tokens
JWT_SECRET=your_strong_jwt_secret_key
JWT_EXPIRES_IN=7d

# OTP Lifetime
OTP_EXPIRES_IN_MINUTES=10

# Frontend URL (required for CORS in production)
FRONTEND_URL=http://localhost:5173

# ==========================================
# OPTIONAL ENVIRONMENT VARIABLES (Warnings logged if missing, but server won't crash)
# ==========================================

# Cloudinary Settings (Optional, needed for image upload)
# Both standard prefixes are supported:
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
# Alternatively supported:
# CLOUD_NAME=your_cloudinary_cloud_name
# API_KEY=your_cloudinary_api_key
# API_SECRET=your_cloudinary_api_secret

# SMTP/Nodemailer Settings (Optional, needed for email verification / OTP login)
# If missing, backend will log a warning and run successfully.
# Auth/register requests requiring OTP will fail gracefully with a 503 response.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_16_digit_gmail_app_password_without_spaces
SMTP_FROM="Auth App <your_email@gmail.com>"
